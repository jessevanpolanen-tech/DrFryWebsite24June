    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <rect width="200" height="200" fill="#FAFAFA"/>
      <g transform="translate(100,100)">
        <path d="M-44 18V-2C-44 -20 -32 -30 -10 -33l3 11c-13 2-20 9-20 19h17v21H-44zm52 0V-2C8 -20 20 -30 42 -33l3 11c-13 2-20 9-20 19h17v21H8z" fill="#F2A23A"/>
      </g>
      <text x="100" y="182" text-anchor="middle" font-family="serif" font-size="14" fill="#111315">Dr. Fry — Voices</text>
    </svg>
  </template>
</body>
</html>
